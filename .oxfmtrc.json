{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": true,
  "tabWidth": 2,
  "printWidth": 140,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "dist/**",
    ".astro/**",
    ".agents/**",
    ".veil/**",
    "node_modules/**",
    ".vercel/**",
    ".conform.*",
    "pnpm-lock.yaml",
    "package-lock.json"
  ],
  "overrides": [
    {
      "files": ["*.json"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
