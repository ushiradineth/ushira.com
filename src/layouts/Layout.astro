---
import CommandPalette from "../components/CommandPalette.astro";
import FloatingTools from "../components/FloatingTools.astro";
import RouteBackLink from "../components/RouteBackLink.astro";
import { ClientRouter } from "astro:transitions";

import { blogWebsite, mainWebsite, personSchema } from "../lib/data/structuredData";

interface Props {
	title: string;
	description: string;
	tags?: string[];
	jsonLd?: string;
}

const currentPathname = Astro.url.pathname;
const ogPathname = currentPathname.endsWith("/") ? currentPathname.slice(0, -1) : currentPathname || "index";

const siteURL = Astro.site?.toString() ?? "";
const site = siteURL[siteURL.length - 1] === "/" ? siteURL.substring(0, siteURL.length - 1) : Astro.site;
const ogImage = new URL(`/og${ogPathname}.png`, site).toString();
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const rssURL = new URL("/rss.xml", site).toString();
const defaultTags = ["Ushira Dineth", "Software Engineer", "Portfolio"];

const { title, description, tags: providedTags, jsonLd: providedJsonLd } = Astro.props;

const tags = [...defaultTags, ...(providedTags ? providedTags : [])];
const jsonLd =
	providedJsonLd ??
	JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [mainWebsite, blogWebsite, personSchema],
	});
---

<!doctype html>
<html lang="en">
	<head>
		<title>{title}</title>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="keywords" content={tags.join(", ")} />
		<meta name="author" content="Ushira Dineth" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content={title} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:type" content="profile" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content="en_GB" />
		<meta property="og:site_name" content="Ushira Dineth" />
		<meta property="twitter:image" content={ogImage} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" type="application/rss+xml" title="Ushira Dineth Blog" href={rssURL} />
		<script type="application/ld+json" set:html={jsonLd} is:inline />
		<script is:inline defer src="https://umami.ushira.com/script.js" data-website-id="b527789a-2e95-4a4a-bafa-8df054b48628"></script>

		<script is:inline>
			const local = localStorage.getItem("theme");
			const system = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

			const theme = local ?? system;
			document.documentElement.classList.remove("light", "dark");
			document.documentElement.classList.add(theme);
		</script>

		<style is:global>
			:root {
				--background: rgb(255 255 255);
				--foreground: rgb(23 23 23);
				--card: rgb(255 255 255);
				--card-foreground: rgb(23 23 23);
				--popover: rgb(255 255 255);
				--popover-foreground: rgb(23 23 23);
				--primary: rgb(23 23 23);
				--primary-foreground: rgb(255 255 255);
				--secondary: rgb(245 245 245);
				--secondary-foreground: rgb(64 64 64);
				--muted: rgb(245 245 245);
				--muted-foreground: rgb(115 115 115);
				--accent: rgb(245 245 245);
				--accent-foreground: rgb(23 23 23);
				--destructive: oklch(0.6271 0.1936 33.339);
				--destructive-foreground: oklch(1 0 0);
				--border: rgb(229 229 229);
				--input: rgb(229 229 229);
				--ring: rgb(64 64 64);
				--chart-1: rgb(23 23 23);
				--chart-2: rgb(82 82 82);
				--chart-3: rgb(163 163 163);
				--chart-4: rgb(212 212 212);
				--chart-5: rgb(245 245 245);
				--sidebar: rgb(255 255 255);
				--sidebar-foreground: rgb(23 23 23);
				--sidebar-primary: rgb(23 23 23);
				--sidebar-primary-foreground: rgb(255 255 255);
				--sidebar-accent: rgb(245 245 245);
				--sidebar-accent-foreground: rgb(23 23 23);
				--sidebar-border: rgb(229 229 229);
				--sidebar-ring: rgb(163 163 163);
				--font-sans: -apple-system, system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
				--font-mono: "Geist Mono Variable", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
				--radius: 0.5rem;
				--shadow-x: 0;
				--shadow-y: 1px;
				--shadow-blur: 3px;
				--shadow-spread: 0px;
				--shadow-opacity: 0.02;
				--shadow-color: oklch(0 0 0);
				--shadow-2xs: none;
				--shadow-xs: none;
				--shadow-sm: none;
				--shadow: none;
				--shadow-md: none;
				--shadow-lg: none;
				--shadow-xl: none;
				--shadow-2xl: none;
				--tracking-normal: 0em;
				--spacing: 0.25rem;
			}

			.dark {
				--background: rgb(10 10 10);
				--foreground: rgb(250 250 250);
				--card: rgb(10 10 10);
				--card-foreground: rgb(250 250 250);
				--popover: rgb(10 10 10);
				--popover-foreground: rgb(250 250 250);
				--primary: rgb(250 250 250);
				--primary-foreground: rgb(10 10 10);
				--secondary: rgb(38 38 38);
				--secondary-foreground: rgb(212 212 212);
				--muted: rgb(23 23 23);
				--muted-foreground: rgb(163 163 163);
				--accent: rgb(23 23 23);
				--accent-foreground: rgb(250 250 250);
				--destructive: oklch(0.6271 0.1936 33.339);
				--destructive-foreground: oklch(1 0 0);
				--border: rgb(38 38 38);
				--input: rgb(64 64 64);
				--ring: rgb(212 212 212);
				--chart-1: rgb(250 250 250);
				--chart-2: rgb(212 212 212);
				--chart-3: rgb(163 163 163);
				--chart-4: rgb(82 82 82);
				--chart-5: rgb(38 38 38);
				--sidebar: rgb(10 10 10);
				--sidebar-foreground: rgb(250 250 250);
				--sidebar-primary: rgb(250 250 250);
				--sidebar-primary-foreground: rgb(10 10 10);
				--sidebar-accent: rgb(23 23 23);
				--sidebar-accent-foreground: rgb(250 250 250);
				--sidebar-border: rgb(38 38 38);
				--sidebar-ring: rgb(163 163 163);
				--font-sans: -apple-system, system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
				--font-mono: "Geist Mono Variable", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
				--radius: 0.5rem;
				--shadow-x: 0;
				--shadow-y: 1px;
				--shadow-blur: 3px;
				--shadow-spread: 0px;
				--shadow-opacity: 0.02;
				--shadow-color: oklch(0 0 0);
				--shadow-2xs: none;
				--shadow-xs: none;
				--shadow-sm: none;
				--shadow: none;
				--shadow-md: none;
				--shadow-lg: none;
				--shadow-xl: none;
				--shadow-2xl: none;
			}

			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				background: var(--background);
				color: var(--foreground);
				font-family: var(--font-sans);
				line-height: 1.6;
			}

			html.theme-switching::view-transition-old(root) {
				animation: theme-curtain 300ms cubic-bezier(0.61, 0.03, 0.08, 1) forwards;
				z-index: 2;
				box-shadow: 0 8px 32px rgb(0 0 0 / 0.25);
			}

			html.theme-switching::view-transition-new(root) {
				animation: none;
				z-index: 1;
			}

			@keyframes theme-curtain {
				from {
					transform: translateY(0);
				}

				to {
					transform: translateY(100vh);
				}
			}
		</style>

		<ClientRouter />
	</head>
	<body class="text-pretty text-foreground antialiased">
		<main role="main" id="main-content" class="mx-auto flex min-h-screen w-full max-w-[52rem] flex-col gap-8 px-6 pb-24 pt-12 sm:px-8 sm:pb-12">
			<RouteBackLink pathname={currentPathname} />
			<CommandPalette />
			<slot />
		</main>
		<FloatingTools />
	</body>
</html>
