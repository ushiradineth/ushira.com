---
import type { CollectionEntry } from "astro:content";

export interface Props {
	label: string;
	post: CollectionEntry<"blog">;
}

const { label, post } = Astro.props;
---

<a
	href={`/blog/${post.slug}`}
	class="group block border-l border-border pl-3 no-underline"
	aria-label={`Read ${label.toLowerCase()} post: ${post.data.title}`}
>
	<p class="text-xs uppercase tracking-[0.05em] text-muted-foreground">{label}</p>
	<p class="text-lg font-medium text-foreground transition-colors group-hover:text-muted-foreground">
		{post.data.title}
	</p>
	<p class="line-clamp-2 text-sm text-muted-foreground">{post.data.description}</p>
</a>
