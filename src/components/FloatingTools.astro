---
import Theme from "./Theme.astro";
---

<div class="pointer-events-none fixed bottom-4 right-4 z-40">
	<div class="pointer-events-auto flex items-center gap-2 rounded-full border border-border bg-background/95 p-2 shadow-sm backdrop-blur-sm">
		<button
			type="button"
			data-command-open
			aria-label="Open command palette"
			class="inline-flex h-8 w-8 items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
		>
			<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<circle cx="11" cy="11" r="7"></circle>
				<path d="m20 20-3.5-3.5"></path>
			</svg>
		</button>
		<div class="inline-flex h-8 w-8 items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">
			<Theme />
		</div>
	</div>
</div>
