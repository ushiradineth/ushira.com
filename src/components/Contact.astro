---
import { requireSocialLink } from "../lib/data/socials";

const contactMethods = [
	{
		title: "Email",
		href: "mailto:hi@ushira.com",
		description: "project work and collaboration",
	},
	{
		title: "LinkedIn",
		href: requireSocialLink("LinkedIn"),
		description: "professional updates",
	},
	{
		title: "GitHub",
		href: requireSocialLink("Github"),
		description: "code and active projects",
	},
	{
		title: "Twitter",
		href: requireSocialLink("Twitter"),
		description: "short technical notes",
	},
	{
		title: "RSS Feed",
		href: "/rss.xml",
		description: "blog updates",
	},
];
---

<section class="w-full space-y-4">
	<h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground">Contact</h2>
	<ul class="space-y-2 text-sm">
		{
			contactMethods.map((method) => {
				const isExternal = method.href.startsWith("http");
				return (
					<li>
						<a
							href={method.href}
							target={isExternal ? "_blank" : undefined}
							rel={isExternal ? "noopener noreferrer" : undefined}
							class="font-medium text-foreground underline-offset-4 transition-colors hover:underline"
						>
							{method.title}
						</a>
						<span class="text-muted-foreground"> - {method.description}</span>
					</li>
				);
			})
		}
	</ul>
	<p class="text-sm text-muted-foreground">
		Share context in your first message and read
		<a href="https://nohello.net/en/" target="_blank" rel="noopener noreferrer" class="font-medium underline underline-offset-4">
			nohello.net
		</a>
		before reaching out.
	</p>
</section>
