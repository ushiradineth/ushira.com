---
import type { MarkdownHeading } from "astro";

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Remove anchor link hash from heading text
const cleanHeadings = headings.map((heading) => ({
	...heading,
	text: heading.text.replace(/\s*#\s*$/, "").trim(),
}));

const visibleHeadings = cleanHeadings.filter((heading) => heading.depth >= 2 && heading.depth <= 4 && heading.text.length > 0);

const levelStylesByDepth: Record<number, { indentClass: string; levelClass: string; markerClass: string }> = {
	2: {
		indentClass: "ml-0",
		levelClass: "text-xs tracking-[0.12em]",
		markerClass: "text-muted-foreground/80",
	},
	3: {
		indentClass: "ml-6",
		levelClass: "text-[0.72rem] tracking-[0.16em]",
		markerClass: "text-muted-foreground/65",
	},
	4: {
		indentClass: "ml-10",
		levelClass: "text-[0.69rem] tracking-[0.18em]",
		markerClass: "text-muted-foreground/50",
	},
};

---

<div class="hide-scrollbar max-h-[calc(100vh-6.5rem)] overflow-y-auto">
	<nav id="toc" class="mt-6 flex flex-col gap-2 text-[0.8125rem]">
		{
			visibleHeadings.map((heading) => {
				const levelStyles = levelStylesByDepth[heading.depth] ?? levelStylesByDepth[2];
				const marker = "-";
				return (
					<a
						href={`#${heading.slug}`}
						data-slug={heading.slug}
						class={`group flex items-start py-1 pl-3 ${levelStyles.indentClass} ${levelStyles.levelClass} uppercase text-muted-foreground transition-colors hover:text-foreground aria-[current=location]:font-semibold aria-[current=location]:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background`}
					>
						<span class="min-w-0 break-words">{heading.text}</span>
					</a>
				);
			})
		}
	</nav>
</div>

<!--Needs to re-run on each page load to evaluate the headings per blog-->
<script is:inline>
	function initTOCObserver() {
		const toc = document.getElementById("toc");
		if (!toc || toc.dataset.initialized === "true") return;
		toc.dataset.initialized = "true";

		const tocLinks = toc.querySelectorAll("a");
		const headings = Array.from(document.querySelectorAll("#blog-body h2, #blog-body h3, #blog-body h4"));

		if (!headings.length) return;

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top);

				if (visible.length > 0) {
					const id = visible[0].target.getAttribute("id");

					tocLinks.forEach((link) => {
						if (link.dataset.slug === id) {
							link.setAttribute("aria-current", "location");
						} else {
							link.removeAttribute("aria-current");
						}
					});
				}
			},
			{ threshold: 0.2, rootMargin: "-10% 0px -55% 0px" },
		);

		headings.forEach((heading) => observer.observe(heading));

		const setCurrentBySlug = (slug) => {
			tocLinks.forEach((link) => {
				if (link.dataset.slug === slug) {
					link.setAttribute("aria-current", "location");
				} else {
					link.removeAttribute("aria-current");
				}
			});
		};

		const initialSlug = window.location.hash.replace(/^#/, "");
		if (initialSlug) setCurrentBySlug(initialSlug);

		// Manual scroll keeps TOC jumps tight despite global anchor offset styles.
		tocLinks.forEach((link) => {
			link.addEventListener("click", (e) => {
				e.preventDefault();

				const slug = link.dataset.slug;
				const target = document.getElementById(slug);
				if (!target) return;

				const top = target.getBoundingClientRect().top + window.scrollY - 16;
				window.scrollTo({ top, behavior: "smooth" });
				window.history.replaceState({}, "", `#${slug}`);
				setCurrentBySlug(slug);
			});
		});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initTOCObserver);
	} else {
		initTOCObserver();
	}
	document.addEventListener("astro:page-load", initTOCObserver);
</script>
