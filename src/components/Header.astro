---
import HeaderItem from "./HeaderItem.astro";
import Theme from "./Theme.astro";
import Logo from "./Logo.astro";
---

<div id="header" class="pb-2">
	<div class="flex items-center justify-between gap-4">
		<a href="/" target="_self" class="text-base font-medium text-foreground">
			<span class="hidden sm:inline">Ushira Dineth</span>
			<Logo class="inline sm:hidden" height={28} width={28} />
		</a>
		<div class="flex items-center gap-3 text-sm">
			<HeaderItem href="/notes/">notes</HeaderItem>
			<HeaderItem href="/projects/">projects</HeaderItem>
			<HeaderItem href="/blog/">blog</HeaderItem>
			<button
				type="button"
				data-command-open
				aria-label="Open command palette"
				class="inline-flex items-center rounded-md border border-border px-2 py-1 text-muted-foreground transition-colors hover:border-foreground/30 hover:text-foreground"
			>
				<kbd data-command-shortcut class="text-[11px] leading-none">⌘ K</kbd>
			</button>
			<Theme />
		</div>
	</div>
</div>
