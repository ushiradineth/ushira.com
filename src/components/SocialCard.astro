---
import { Icon } from "astro-icon/components";

import type { Social } from "../lib/types";

interface Props {
	social: Social;
}

const { social } = Astro.props;
---

<div class="group h-full w-full list-none rounded-lg bg-secondary">
	<a href={social.href} class="flex flex-col p-6">
		<div class="flex items-center justify-center">
			<div class="flex items-center justify-center gap-2">
				<p class="font-light"><Icon name={social.icon} /><p class="text-chart-1">•</p></p>
				<h2 class="text-xl font-semibold">
					{social.title}
				</h2>
			</div>
			<div class="ml-auto transition-transform duration-300 group-hover:-rotate-12">&rarr;</div>
		</div>
		<p>{social.description}</p>
	</a>
</div>
