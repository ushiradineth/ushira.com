---
import { Icon } from "astro-icon/components";

interface Props {
	icon: string;
	name: string;
}

const { icon, name } = Astro.props;
---

<span class="flex items-center gap-2 rounded-lg border border-border bg-muted/30 px-4 py-2.5 text-base text-foreground">
	<Icon name={icon} class="h-5 w-5 text-muted-foreground" />
	{name}
</span>
