---
import type { HomeLinkGroup as HomeLinkGroupType } from "../lib/data/home";

interface Props {
	group: HomeLinkGroupType;
}

const { group } = Astro.props;
---

<div class="space-y-2">
	<h3 class="text-xs font-medium uppercase tracking-[0.05em] text-muted-foreground">{group.title}</h3>
	<ul class="space-y-2 text-sm">
		{
			group.items.map((item) => {
				const isExternal = item.href.startsWith("http");
				const previewUrl = item.previewUrl ?? (isExternal ? item.href : undefined);

				return (
					<li>
						<a
							href={item.href}
							target={isExternal ? "_blank" : undefined}
							rel={isExternal ? "noopener noreferrer" : undefined}
							class="preview-link font-medium underline-offset-4 hover:underline"
							data-preview-url={previewUrl}
						>
							{item.name}
						</a>
						<span class="text-muted-foreground"> - {item.description}</span>
					</li>
				);
			})
		}
	</ul>
</div>
