---
import { Icon } from "astro-icon/components";
import { getLast7DaysStats, getLastYearStats, getAllTimeStats, getActivityChartSvg, formatTime } from "../lib/data/wakapi";

// Fetch stats at build time
const last7DaysStats = await getLast7DaysStats();
const lastYearStats = await getLastYearStats();
const allTimeStats = await getAllTimeStats();
const activityChartSvg = await getActivityChartSvg();

// If no stats are available, don't render the component
if (!last7DaysStats && !lastYearStats && !allTimeStats) {
	return null;
}

// Get top language for each timeframe
const topLangLast7Days = last7DaysStats?.data?.languages?.[0]?.name || "N/A";
const topLangLastYear = lastYearStats?.data?.languages?.[0]?.name || "N/A";
const topLangAllTime = allTimeStats?.data?.languages?.[0]?.name || "N/A";
---

<div class="flex flex-col gap-6">
	<div class="flex items-center gap-2">
		<Icon name="mdi:code-braces" class="h-6 w-6 text-primary" />
		<h2 class="text-2xl font-bold">Coding Activity</h2>
	</div>

	<!-- Hours Active - Last 7 Days -->
	{
		last7DaysStats?.data && (
			<div class="rounded-lg border border-border bg-card p-6">
				<div class="mb-4 flex items-center gap-2">
					<Icon name="mdi:calendar-week" class="h-5 w-5 text-muted-foreground" />
					<h3 class="text-lg font-semibold">Last 7 Days</h3>
				</div>
				<div class="flex items-baseline gap-2">
					<p class="text-3xl font-bold text-primary">{formatTime(last7DaysStats.data.total_seconds)}</p>
				</div>
				<p class="mt-2 text-sm text-muted-foreground">
					Avg {formatTime(last7DaysStats.data.daily_average)} per day
				</p>
			</div>
		)
	}

	<!-- Most Used Languages -->
	<div class="grid grid-cols-1 gap-4 md:grid-cols-3">
		<div class="rounded-lg border border-border bg-card p-6">
			<div class="mb-2 flex items-center gap-2">
				<Icon name="mdi:code-tags" class="h-5 w-5 text-muted-foreground" />
				<h3 class="font-semibold">Last 7 Days</h3>
			</div>
			<p class="text-2xl font-bold text-primary">{topLangLast7Days}</p>
			<p class="mt-1 text-xs text-muted-foreground">Most used language</p>
		</div>

		<div class="rounded-lg border border-border bg-card p-6">
			<div class="mb-2 flex items-center gap-2">
				<Icon name="mdi:code-tags" class="h-5 w-5 text-muted-foreground" />
				<h3 class="font-semibold">Last Year</h3>
			</div>
			<p class="text-2xl font-bold text-primary">{topLangLastYear}</p>
			<p class="mt-1 text-xs text-muted-foreground">Most used language</p>
		</div>

		<div class="rounded-lg border border-border bg-card p-6">
			<div class="mb-2 flex items-center gap-2">
				<Icon name="mdi:code-tags" class="h-5 w-5 text-muted-foreground" />
				<h3 class="font-semibold">All Time</h3>
			</div>
			<p class="text-2xl font-bold text-primary">{topLangAllTime}</p>
			<p class="mt-1 text-xs text-muted-foreground">Most used language</p>
		</div>
	</div>

	<!-- Language Breakdown - Last 7 Days -->
	{
		last7DaysStats?.data?.languages && last7DaysStats.data.languages.length > 0 && (
			<div class="rounded-lg border border-border bg-card p-6">
				<div class="mb-4 flex items-center gap-2">
					<Icon name="mdi:chart-bar" class="h-5 w-5 text-muted-foreground" />
					<h3 class="text-lg font-semibold">Language Breakdown</h3>
					<span class="ml-auto text-xs text-muted-foreground">Last 7 days</span>
				</div>
				<div class="space-y-3">
					{last7DaysStats.data.languages.slice(0, 5).map((lang) => (
						<div class="flex items-center gap-3">
							<div class="flex-1">
								<div class="mb-1 flex items-center justify-between">
									<span class="text-sm font-medium">{lang.name}</span>
									<div class="flex items-center gap-2">
										<span class="text-xs text-muted-foreground">{lang.text}</span>
										<span class="text-xs text-muted-foreground">•</span>
										<span class="text-xs text-muted-foreground">{lang.percent.toFixed(1)}%</span>
									</div>
								</div>
								<div class="h-2 w-full overflow-hidden rounded-full bg-muted">
									<div class="h-full bg-primary transition-all duration-500" style={`width: ${lang.percent}%`} />
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		)
	}


	<!-- Wakapi Activity Chart -->
	{
		activityChartSvg && (
			<div class="rounded-lg border border-border bg-card p-6">
				<div class="mb-4 flex items-center gap-2">
					<Icon name="mdi:chart-scatter-plot" class="h-5 w-5 text-muted-foreground" />
					<h3 class="text-lg font-semibold">Coding Activity Heatmap</h3>
				</div>
				<div class="w-full rounded-lg" set:html={activityChartSvg} />
			</div>
		)
	}

	<!-- GitHub Contribution Chart -->
	<div class="rounded-lg border border-border bg-card p-6">
		<div class="mb-4 flex items-center gap-2">
			<Icon name="mdi:github" class="h-5 w-5 text-muted-foreground" />
			<h3 class="text-lg font-semibold">GitHub Contributions</h3>
		</div>
		<div class="overflow-hidden rounded-lg">
			<img
				src="https://ghchart.rshah.org/2F855A/ushiradineth"
				alt="GitHub Contribution Chart"
				class="w-full"
				loading="lazy"
			/>
		</div>
	</div>
</div>
