---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata | string;
	alt?: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
const figureCaption = caption ?? alt;
const isRemoteImage = typeof src === "string";
---

<figure class="space-y-2">
	{
		isRemoteImage ? (
			<img src={src} alt={alt ?? ""} loading="lazy" decoding="async" class="w-full border border-border" />
		) : (
			<Image src={src} alt={alt ?? ""} class="w-full border border-border" />
		)
	}
	{figureCaption && <figcaption class="border-l border-border pl-3 text-sm text-muted-foreground">{figureCaption}</figcaption>}
</figure>
