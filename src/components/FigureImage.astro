---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
const figureCaption = caption ?? alt;
---

<figure class="my-6 overflow-hidden rounded-xl border border-border bg-background/40">
	<Image src={src} alt={alt} class="w-full" />
	<figcaption class="px-4 py-2 text-sm text-muted">{figureCaption}</figcaption>
</figure>
