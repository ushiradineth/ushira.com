---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
const figureCaption = caption ?? alt;
---

<figure class="overflow-hidden rounded-lg border border-border bg-background/40">
	<Image src={src} alt={alt} class="w-full" />
	<figcaption class="m-4 text-sm text-muted-foreground">{figureCaption}</figcaption>
</figure>
