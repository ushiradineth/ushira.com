---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
const figureCaption = caption ?? alt;
---

<figure class="space-y-2">
	<Image src={src} alt={alt} class="w-full border border-border" />
	<figcaption class="border-l border-border pl-3 text-sm text-muted-foreground">{figureCaption}</figcaption>
</figure>
