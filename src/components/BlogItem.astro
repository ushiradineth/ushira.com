---
import type { CollectionEntry } from "astro:content";
import { formatDate, isWithinDays } from "../lib/utils";
import Badge from "./Badge.astro";

interface Props {
	post: CollectionEntry<"blog">;
	class?: string;
}

const { post, class: className } = Astro.props;

const { data } = post;
const tags = data.tags ?? [];
const publishedDate = data.date;
const isFuture = publishedDate ? publishedDate.getTime() > Date.now() : false;
const isNew = publishedDate && !isFuture ? isWithinDays(publishedDate, 30) : false;
const formattedDate = publishedDate && !isFuture ? formatDate(publishedDate) : "Coming Soon";
const href = `/blog/${post.slug}/`;
---

<a href={href} class={`block rounded-lg py-4 transition-colors hover:bg-accent/40 ${className ?? ""}`}>
	<div class="flex w-full flex-col gap-4 sm:gap-3">
		<div class="flex flex-col gap-4">
			<div class="flex flex-col gap-2 font-semibold sm:flex-row sm:items-start sm:justify-between">
				<h2 class="flex items-center gap-2 text-lg sm:text-xl">
					<span>{data.title}</span>
					{isNew && (
						<span class="inline-flex items-center rounded-full bg-emerald-500/15 px-2 text-xs font-semibold uppercase tracking-wide text-emerald-500">
							New
						</span>
					)}
				</h2>
				<span class="flex shrink-0 items-center gap-2 text-sm text-muted">
					<p>{formattedDate}</p>
					<span class={isFuture ? "text-yellow-500" : "text-green-500"} aria-hidden="true">
						•
					</span>
				</span>
			</div>
			{data.description && <p class="text-sm text-muted sm:text-base">{data.description}</p>}
		</div>
		<div class="flex flex-wrap items-center justify-start gap-1">
			{tags.map((tag) => (
				<Badge>#{tag}</Badge>
			))}
		</div>
	</div>
</a>
