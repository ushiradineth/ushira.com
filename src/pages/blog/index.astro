---
import BlogItem from "../../components/BlogItem.astro";
import Title from "../../components/Title.astro";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { border } from "../../lib/utils";

const blogPosts = (await getCollection("blog")).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Blog Posts" description="ushira.com">
	<Title>Blog Posts</Title>
	<div class="flex w-full flex-col">
		{blogPosts.map((post, index) => <BlogItem post={post} class={`border-border ${border(index, blogPosts.length)}`} />)}
	</div>
</Layout>
