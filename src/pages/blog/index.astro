---
import Title from "../../components/Title.astro";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/utils";
import Tag from "../../components/Tag.astro";

const blogPosts = (await getCollection("blog")).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Get all unique tags
const allTags = [...new Set(blogPosts.flatMap((post) => post.data.tags ?? []))].sort();
---

<Layout title="Blog Posts" description="ushira.com">
	<Title>Blog Posts</Title>
	<p class="text-muted-foreground">Personal blog posts, notes, and other ramblings.</p>

	<div class="text-sm" data-blog-page>
			<div class="flex flex-wrap gap-2">
				{allTags.map((tag) => (
					<Tag class="tag-filter" data-tag={tag}>
						#{tag}
					</Tag>
				))}
				<Tag class="tag-filter" data-tag="clear">
					(clear)
				</Tag>
			</div>

		<div class="mt-12 flex flex-col gap-6">
			{blogPosts.map((post) => {
				const tags = post.data.tags ?? [];
				return (
					<article class="blog-post border-b border-border pb-6" data-tags={tags.join(",")}>
						<div class="flex items-baseline gap-3">
							<a href={`/blog/${post.slug}/`} class="text-base font-semibold hover:text-primary hover:underline underline-offset-4">
								{post.data.title}
							</a>
						</div>
						{post.data.description && <p class="mt-2 text-sm text-muted-foreground">{post.data.description}</p>}
          <div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
              <span class="text-muted-foreground">{formatDate(post.data.date)}</span>
              <span class="text-muted-foreground">{"|"}</span>
							<div class="post-tags flex flex-wrap gap-2">
								{tags.map((tag) => (
									<Tag class="tag-badge" data-tag={tag}>#{tag}</Tag>
								))}
							</div>
						</div>
					</article>
				);
			})}
		</div>
	</div>
</Layout>

<script>
	function initTagFilter() {
		const page = document.querySelector<HTMLElement>('[data-blog-page]');
		if (!page || page.dataset.initialized === 'true') return;
		page.dataset.initialized = 'true';

		const tagFilters = page.querySelectorAll<HTMLButtonElement>('.tag-filter');
		const blogPosts = page.querySelectorAll<HTMLElement>('.blog-post');
		const clearButton = page.querySelector<HTMLButtonElement>('[data-tag="clear"]');
		const tagBadges = page.querySelectorAll<HTMLButtonElement>('.tag-badge');
		const resultCount = page.querySelector<HTMLElement>('[data-result-count]');

		let activeTag: string | null = null;

		function getPostTags(post: Element) {
			return (post.getAttribute('data-tags') ?? '').split(',').filter(Boolean);
		}

		function updateTagButtons() {
			tagFilters.forEach(btn => {
				const tag = btn.getAttribute('data-tag');
				if (tag === 'clear') return;
				const isActive = tag === activeTag;
				btn.classList.toggle('active', isActive);
				btn.classList.toggle('text-primary', isActive);
				btn.classList.toggle('text-foreground', !isActive);
			});
			clearButton?.classList.toggle('hidden', !activeTag);
		}

		function updatePosts() {
			blogPosts.forEach(post => {
				const postTags = getPostTags(post);
				const matchesTag = !activeTag || postTags.includes(activeTag);
				post.style.display = matchesTag ? '' : 'none';
			});

			const visibleTags = new Set<string>();
			Array.from(blogPosts)
				.filter(post => post.style.display !== 'none')
				.forEach(post => {
					getPostTags(post).forEach(tag => visibleTags.add(tag));
				});

			tagFilters.forEach(btn => {
				const tag = btn.getAttribute('data-tag');
				if (!tag || tag === 'clear') return;
				if (tag === activeTag) {
					btn.style.display = '';
					return;
				}
				btn.style.display = visibleTags.has(tag) ? '' : 'none';
			});

			const visibleTotal = Array.from(blogPosts).filter(post => post.style.display !== 'none').length;
			if (resultCount) resultCount.textContent = String(visibleTotal);
		}

		function updateUrl() {
			const params = new URLSearchParams();
			if (activeTag) params.set('tag', activeTag);
			const suffix = params.toString();
			window.history.replaceState({}, '', suffix ? `/blog/?${suffix}` : '/blog/');
		}

		function setActiveTag(tag: string | null) {
			activeTag = tag;
			updateTagButtons();
			updatePosts();
			updateUrl();
		}

		const urlParams = new URLSearchParams(window.location.search);
		const urlTag = urlParams.get('tag');
		if (urlTag) activeTag = urlTag;

		updateTagButtons();
		updatePosts();
		updateUrl();

		tagFilters.forEach(button => {
			button.addEventListener('click', () => {
				const selectedTag = button.getAttribute('data-tag');
				if (!selectedTag) return;
				setActiveTag(selectedTag === 'clear' ? null : selectedTag);
			});
		});

		tagBadges.forEach(button => {
			button.addEventListener('click', () => {
				const selectedTag = button.getAttribute('data-tag');
				if (!selectedTag) return;
				setActiveTag(selectedTag);
			});
		});

	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initTagFilter);
	} else {
		initTagFilter();
	}
	document.addEventListener('astro:page-load', initTagFilter);
</script>
