---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { isWithinDays } from "../lib/utils";
import HomeLinkGroup from "../components/HomeLinkGroup.astro";
import Title from "../components/Title.astro";
import { homeAppGroups, homeMainStack } from "../lib/data/home";
import HeaderItem from "../components/HeaderItem.astro";

const blogs = await getCollection("blog");
const hasNewBlog = blogs.some((post) => {
	const { date } = post.data;
	if (!date || Number.isNaN(date.getTime())) return false;
	return isWithinDays(date, 30);
});
---

<Layout title="Ushira Dineth" description="ushira.com">
	<section class="space-y-4">
		<Title>Ushira Dineth</Title>
		<p class="text-foreground">
			Infrastructure and Backend engineer @
			<a href="https://surge.global/" class="underline underline-offset-4 transition-colors hover:text-muted-foreground">surge.global</a>
		</p>
		<ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-muted-foreground">
			{homeMainStack.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="space-y-2">
		<h2 class="text-sm font-medium uppercase tracking-[0.05em] text-muted-foreground">Explore</h2>
		<div class="flex flex-wrap gap-2 text-sm">
			<HeaderItem href="/projects/">projects</HeaderItem>
			<HeaderItem href="/notes/">notes</HeaderItem>
			<HeaderItem href="/blog/">
				<span class="relative pr-1">
					blog
					{hasNewBlog && <span class="absolute -right-0.5 h-1.5 w-1.5 rounded-full bg-amber-400 shadow-sm" aria-hidden="true" />}
				</span>
			</HeaderItem>
		</div>
	</section>

	<section class="flex flex-col space-y-3 gap-4">
		{homeAppGroups.map((group) => <HomeLinkGroup group={group} />)}
	</section>

	<p class="text-sm text-muted-foreground">
		Share context in your first message and read
		<a href="https://nohello.net/en/" target="_blank" rel="noopener noreferrer" class="font-medium underline underline-offset-4">
			nohello.net
		</a>
		before reaching out.
	</p>
</Layout>
