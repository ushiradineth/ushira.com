---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDate, isWithinDays } from "../lib/utils";
import Contact from "../components/Contact.astro";

const blogs = await getCollection("blog");
const latestNewBlog =
	blogs
		.filter((post) => {
			const { date } = post.data;
			if (!date || Number.isNaN(date.getTime())) return false;
			if (date.getTime() > Date.now()) return false;
			return isWithinDays(date, 30);
		})
		.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0] ?? null;
---

<Layout title="Ushira Dineth" description="ushira.com">
	{
		latestNewBlog && (
			<section class="mb-6 flex items-center gap-2 rounded-lg border border-chart-1/40 bg-chart-1/5 px-4 py-3 text-sm text-muted-foreground">
				<span class="inline-flex items-center rounded bg-chart-1 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-background">
					New
				</span>
				<a class="flex-1 font-semibold text-chart-1 hover:underline" href={`/blog/${latestNewBlog.slug}/`}>
					{latestNewBlog.data.title}
				</a>
				<span class="text-xs uppercase tracking-wide">{latestNewBlog.data.date ? formatDate(latestNewBlog.data.date) : ""}</span>
			</section>
		)
	}

	<div class="flex flex-col gap-8 md:gap-16">
		<div class="space-y-6 text-foreground text-xl">
			<p>
				I’m a software engineer based in Sri Lanka, working on distributed systems, infrastructure, and product engineering. Currently at{
					" "
				}
				<a
					href="https://surge.global/"
					class="font-medium text-primary underline decoration-primary/30 underline-offset-2 hover:decoration-primary"
				>
					Surge Global, Colombo
				</a>.
			</p>

			<p>
				I work primarily with Kubernetes, Go, TypeScript, and Terraform. I care about reliability, reproducibility, and systems that are
				boring by design. My goal is to automate myself out of work.
			</p>

			<p>
				More context, opinions, and work-in-progress notes live in{" "}
				<a href="/notes/" class="font-medium text-primary underline decoration-primary/30 underline-offset-2 hover:decoration-primary">
					the notes
				</a>.
			</p>

			<p>
				Technical writing lives on{" "}
				<a href="/blog/" class="font-medium text-primary underline decoration-primary/30 underline-offset-2 hover:decoration-primary">
					the blog
				</a>.
			</p>
		</div>

		<Contact />
	</div>
</Layout>
