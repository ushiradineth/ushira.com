---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import NoteCard from "../../components/NoteCard.astro";

const learning = [
	{
		topic: "Network programming",
		description: "I want to learn how to program network protocols, especially for low latency multiple player games",
	},
	{
		topic: "Game engines",
		description: "I want to learn how to program game engines, I'm tinkering with Godot and Raylib right now",
	},
	{
		topic: "MLOps",
		description: "I want to learn how to support AI workloads on Kubernetes",
	},
];
---

<Layout title="Learning" description="What I'm currently exploring and building expertise in">
	<div class="space-y-8">
		<div class="space-y-3">
			<a href="/notes/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground">
				<Icon name="mdi:arrow-left" class="h-4 w-4" />
				Back to Notes
			</a>
			<h1 class="text-4xl font-bold text-foreground">Learning</h1>
			<p class="text-lg text-muted-foreground">What I'm currently exploring and building expertise in.</p>
		</div>

		<div class="space-y-4">
			{
				learning.map((item) => (
					<NoteCard icon="mdi:lightbulb-on" title={item.topic}>
						<p>{item.description}</p>
					</NoteCard>
				))
			}
		</div>

		<div class="rounded-lg border border-border bg-muted/20 p-6">
			<p class="text-muted-foreground">
				This list evolves as I explore new domains. These are areas where I'm actively building projects, reading research, and
				experimenting outside of work.
			</p>
		</div>
	</div>
</Layout>
