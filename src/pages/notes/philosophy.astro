---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import NoteCard from "../../components/NoteCard.astro";

const principles = [
	{
		title: "Problem Solver First",
		icon: "mdi:puzzle",
		description: [
			'I\'ve always seen myself first and foremost as a problem solver, so trying to be a "jack of all trades" has always appealed to me.',
			"I don't limit myself to a single domain or technology. If there's a problem worth solving, I'll learn what's needed to solve it.",
		],
	},
	{
		title: "No Fluff",
		icon: "mdi:filter",
		description: [
			"I try to keep the website free of fluff, this is not meant to market myself for recruitment.",
			"This site exists to document who I am and how I work, not to optimize for someone else's hiring criteria.",
		],
	},
	{
		title: "Plan Mode",
		icon: "mdi:bookmark-box",
		description: [
			"Even prior to the AI era, I've always spent more time planning and documenting my work than actually doing it.",
			"This skill is even more valuable now with AI Agents, and it makes documentation and context tracking a breeze even when working on multiple projects and tasks.",
		],
	},
];
---

<Layout title="Philosophy" description="How I think about work, problems, and building systems">
	<div class="space-y-8">
		<div class="space-y-3">
			<a href="/notes/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground">
				<Icon name="mdi:arrow-left" class="h-4 w-4" />
				Back to Notes
			</a>
			<h1 class="text-4xl font-bold text-foreground">Philosophy</h1>
			<p class="text-lg text-muted-foreground">How I think about work, problems, and building systems.</p>
		</div>

		<div class="space-y-4">
			{
				principles.map((principle) => (
					<NoteCard icon={principle.icon} title={principle.title}>
						{principle.description.map((desc) => (
							<p>{desc}</p>
						))}
					</NoteCard>
				))
			}
		</div>
	</div>
</Layout>
