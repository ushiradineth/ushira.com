---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import NoteCard from "../../components/NoteCard.astro";

const practices = [
	{
		title: "Declarative Everything",
		icon: "mdi:code-braces",
		description: [
			"If I can't reproduce it with code, it doesn't exist. Terraform, Helm, GitOps, Nix, Ansible, good old fashioned bash scripts etc etc.",
			"I'm tired of tinkering with clunky UIs, even if it's a one time thing. I'm a big fan of declarative configurations.",
		],
	},
	{
		title: "Automate/Document Myself Out of the Job",
		icon: "mdi:shield-check",
		description: [
			"I do not want to be stuck in one task or project for an extended period of time. I want to be able to automate myself out of the job. All work I do is documented, to the point where anyone can fill in easily or feed it to a LLM and get going.",
			"Job security comes from leverage, not hoarding knowledge.",
		],
	},
	{
		title: "Terminal-First Workflow",
		icon: "mdi:terminal",
		description: [
			"Most work I do is done through a terminal. I'm a big fan of ghostty, tmux, neovim, lazygit, claude code etc.",
			"I love TUIs, and I love not wasting my battery on clunky electron apps.",
		],
	},
];
---

<Layout title="How I Work" description="Principles, workflows, and automation mindset">
	<div class="space-y-8">
		<div class="space-y-3">
			<a href="/notes/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground">
				<Icon name="mdi:arrow-left" class="h-4 w-4" />
				Back to Notes
			</a>
			<h1 class="text-4xl font-bold text-foreground">How I Work</h1>
			<p class="text-lg text-muted-foreground">Principles, workflows, and automation mindset.</p>
		</div>

		<div class="space-y-4">
			{
				practices.map((practice) => (
					<NoteCard icon={practice.icon} title={practice.title}>
						{practice.description.map((desc) => (
							<p>{desc}</p>
						))}
					</NoteCard>
				))
			}
		</div>
	</div>
</Layout>
