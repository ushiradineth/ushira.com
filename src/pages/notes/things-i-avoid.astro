---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import NoteCard from "../../components/NoteCard.astro";

const avoidances = [
	{
		topic: "Document DBs",
		description: [
			"I want my data to have structure and consistency. I understand that Document DBs are great for some use cases, but I will continue to feign ignorance for my own sanity.",
		],
	},
	{
		topic: "Java and JavaScript",
		description: ["Different languages, same outcome for my workflow. I avoid both when I can."],
	},
	{
		topic: "Azure",
		description: ["I've used it. The UI and support workflows consistently slow me down compared to GCP or AWS."],
	},
	{
		topic: "Finder in macOS",
		description: ["How does the 'most user friendly OS' not have a good file browser?"],
	},
	{
		topic: "Nx",
		description: ["Just use turborepo."],
	},
];
---

<Layout title="Things I Avoid" description="Technologies and patterns I stay away from">
	<div class="space-y-8">
		<div class="space-y-3">
			<a href="/notes/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground">
				<Icon name="mdi:arrow-left" class="h-4 w-4" />
				Back to Notes
			</a>
			<h1 class="text-4xl font-bold text-foreground">Things I Avoid</h1>
			<p class="text-lg text-muted-foreground">Technologies and patterns I stay away from.</p>
		</div>

		<div class="space-y-4">
			{
				avoidances.map((item) => (
					<NoteCard icon="mdi:alert-circle" title={item.topic}>
						{item.description.map((desc) => (
							<p>{desc}</p>
						))}
					</NoteCard>
				))
			}
		</div>

		<div class="rounded-lg border border-border bg-muted/20 p-6">
			<p class="text-sm text-muted-foreground">
				These are personal preferences based on my workflow and experiences. Your mileage may vary. I'm not here to convince you.
			</p>
		</div>
	</div>
</Layout>
