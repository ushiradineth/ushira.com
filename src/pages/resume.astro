---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getWebPageJsonLd } from "../lib/data/structuredData";

const resumeFileId = "1NVYbVdsrnCtMkfZ6hjuiUI3GYwD5mA0d";
const resumeViewUrl = `https://drive.google.com/file/d/${resumeFileId}/view`;
const resumeEmbedUrl = `https://drive.google.com/file/d/${resumeFileId}/preview`;

const title = "Resume - Ushira Dineth";
const description =
	"Resume of Ushira Dineth, Senior DevOps & Infrastructure Engineer with 3+ years of experience in Kubernetes, Terraform, and cloud infrastructure";
const url = `${import.meta.env.SITE}/resume/`;
const jsonLd = getWebPageJsonLd(url, title, description);
---

<Layout title={title} description={description} jsonLd={jsonLd}>
	<!-- Header -->
	<div class="mb-6 flex items-center justify-between gap-4">
		<h1 class="text-3xl font-bold text-foreground">Resume</h1>
		<div class="flex gap-2">
			<a
				href={resumeViewUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-2 rounded-lg border border-primary bg-primary px-4 py-2 text-sm font-semibold text-background transition-all hover:bg-primary/90"
			>
				<Icon name="mdi:download" class="h-5 w-5 text-background" />
				<span>Download PDF</span>
			</a>
		</div>
	</div>

	<!-- Google Drive Preview -->
	<div class="overflow-hidden rounded-lg border border-border bg-background">
		<iframe src={resumeEmbedUrl} class="h-[800px] w-full" allow="autoplay" title="Resume - Ushira Dineth"></iframe>
	</div>

	<!-- Footer Note -->
	<div class="mt-6 text-center text-sm text-muted-foreground">
		<p>
			This resume is hosted on Google Drive and always reflects the latest version.
			<a href={resumeViewUrl} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline"> Open in Google Drive </a>
		</p>
	</div>
</Layout>
