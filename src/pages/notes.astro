---
import Layout from "../layouts/Layout.astro";
import Title from "../components/Title.astro";
import { Icon } from "astro-icon/components";
import { getWebPageSchema, mainWebsite, personSchema } from "../lib/data/structuredData";
import { getCollection } from "astro:content";

const description = "My preferences, philosophies, and opinions on software and work";
const url = `${import.meta.env.SITE}/notes/`;

const webPageSchema = getWebPageSchema(url, "Notes", description);
const jsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@graph": [webPageSchema, mainWebsite, personSchema],
});

const notes = (await getCollection("notes")).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Notes" description={description} jsonLd={jsonLd}>
	<div class="space-y-8">
		<div class="space-y-3">
			<Title>Notes</Title>
			<p class="text-lg text-muted-foreground">Personal opinions, preferences, and thoughts on software engineering and work.</p>
		</div>

		<div class="grid gap-4 sm:grid-cols-2">
			{
				notes.map((note) => (
					<a
						href={`/notes/${note.slug}/`}
						class="group flex flex-col gap-3 rounded-lg border border-border bg-background p-6 transition-all hover:border-primary hover:bg-muted/30"
					>
						<div class="flex items-center gap-3">
							<Icon name={note.data.icon} class="h-6 w-6 text-muted-foreground group-hover:text-primary" />
							<h2 class="text-xl font-semibold text-foreground">{note.data.title}</h2>
						</div>
						<p class="text-sm text-muted-foreground">{note.data.description}</p>
					</a>
				))
			}
		</div>
	</div>
</Layout>
