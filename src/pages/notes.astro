---
import Layout from "../layouts/Layout.astro";
import Title from "../components/Title.astro";
import { getWebPageJsonLd } from "../lib/data/structuredData";
import { getCollection } from "astro:content";

const description = "My preferences, philosophies, and opinions on software and work";
const url = `${import.meta.env.SITE}/notes/`;
const jsonLd = getWebPageJsonLd(url, "Notes", description);

const notes = (await getCollection("notes")).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Notes" description={description} jsonLd={jsonLd}>
	<section class="space-y-3">
		<Title>Notes</Title>
		<p class="text-sm text-muted-foreground">Personal preferences, principles, and working notes.</p>
	</section>

	<section class="space-y-3 text-sm">
		{
			notes.map((note) => (
				<article class="border-b border-border pb-3 last:border-0">
					<h2>
						<a href={`/notes/${note.id}/`} class="font-medium text-foreground underline-offset-4 hover:underline">
							{note.data.title}
						</a>
					</h2>
					<p class="text-muted-foreground">{note.data.description}</p>
				</article>
			))
		}
	</section>
</Layout>
